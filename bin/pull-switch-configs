#!/bin/bash
# replace the old switch puller shell script with ansible via our connection
# plugin. This is way more reliable as it no longer relies on scp/sftp/...
# working on the switch.
#
# From user perspective this should behave just like the old script.

_role_paths=$(awk -F'=[[:space:]]*' '/^roles_path/ {print $2}' ansible.cfg | tr ':' ' ')
# create a comma separated list from multiple arguments
_limit_list=$(IFS=,; echo "$*")

if [ -f playbooks/pull-switch-configs.yml ]; then
    _playbook=playbooks/pull-switch-configs.yml
else
    for dir in ${_role_paths:-roles}; do
        _f="$dir/data-utilities/playbooks/pull-switch-configs.yml"
        if [ -f "$_f" ]; then
            _playbook=$_f
            break
        fi
    done
fi

if [ -n "${_playbook}" ]; then
    ansible-playbook ${_playbook} -l "${_limit_list:-switches}"
else
    echo "pull-switch-configs.yml not found"
    exit 1
fi

if [ -f .switches ]; then
    echo ".switches is no longer used - configuration comes from Ansible"
fi
