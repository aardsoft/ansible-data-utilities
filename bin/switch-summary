#!/usr/bin/env python3
"""Print a normalized summary of a switch config file."""

import argparse
import os
import sys

# Allow running directly from repo root
_repo_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _repo_root not in sys.path:
    sys.path.insert(0, _repo_root)

from switch_utils import parse, format_summary
from switch_utils.detect import detect_dialect


def main():
    parser = argparse.ArgumentParser(
        description='Print a normalized summary of a switch config file.')
    parser.add_argument('configs', nargs='+', metavar='FILE',
                        help='Switch config file(s) to summarise')
    parser.add_argument('--dialect', metavar='DIALECT',
                        help='Force dialect (routeros, zyxel_xgs, fs_generic, '
                             'fs_gigaeth, fs_vrp, hpe_procurve)')
    parser.add_argument('--verbose', '-v', action='store_true',
                        help='Show port warnings and unhandled sections')
    parser.add_argument('--detect-only', action='store_true',
                        help='Only detect and print dialect, do not parse')
    args = parser.parse_args()

    rc = 0
    for path in args.configs:
        if len(args.configs) > 1:
            print('--- %s ---' % path)
        try:
            with open(path) as f:
                content = f.read()
        except OSError as e:
            print('ERROR: cannot read %s: %s' % (path, e), file=sys.stderr)
            rc = 1
            continue

        if args.detect_only:
            print('%s: %s' % (path, detect_dialect(content)))
            continue

        cfg = parse(content, dialect=args.dialect)
        print(format_summary(cfg, verbose=args.verbose))

        if cfg.errors:
            rc = 1

    return rc


if __name__ == '__main__':
    sys.exit(main())
