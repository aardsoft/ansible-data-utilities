{
    "default_vars": {
        "dns_domain": "ci-demo.aardsoft.fi"
    },
    "hosts": {
        "microgw": {
            "host_vars": {
                "ansible_host": "127.0.0.1",
                "ansible_port": 60322,
                "debug_variables": true,
                "dhcp_boot": true,
                "dhcpd": {
                    "chroot": false
                }
            },
            "networks": {
                "enp0s5": {
                    "cfg_prefix": "10",
                    "dns_iface_domain": "ci-demo.aardsoft.fi",
                    "dns_name": "microgw.ci-demo.aardsoft.fi",
                    "masquerade": "both",
                    "static": false
                },
                "enp0s6": {
                    "addresses": {
                        "10.11.12.1/24": {
                            "host_duplicate": true
                        }
                    },
                    "cfg_prefix": "10",
                    "dhcp_network": "demo",
                    "dns_iface_domain": "ci-demo.aardsoft.fi",
                    "dns_name": "microgw.ci-demo.aardsoft.fi",
                    "ipv4": "10.11.12.1/24",
                    "masquerade": "both",
                    "static": true
                }
            },
            "rack_mounted": 0,
            "type": "notebook"
        }
    },
    "networks": {
        "demo": {
            "dhcp_domain_name": "\"demo.ci-demo.aardsoft.fi\"",
            "dhcp_domain_search": "\"demo.ci-demo.aardsoft.fi\", \"ci-demo.aardsoft.fi\"",
            "reverse_zones": {
                "10.11.12.0/24": "12.11.10.in-addr.arpa"
            },
            "subnets": {
                "10.11.12.0/24": {
                    "boot_options": {
                        "pxe": [
                            "next-server 10.11.12.1"
                        ]
                    },
                    "options": [
                        "range 10.11.12.150 10.11.12.200",
                        "option routers 10.11.12.1",
                        "option ntp-servers 10.11.12.1",
                        "option domain-name-servers 10.11.12.1"
                    ],
                    "subnet_netmask": "255.255.255.0",
                    "subnet_network": "10.11.12.0"
                }
            }
        }
    },
    "vlans": {
        "demo": "5000"
    }
}